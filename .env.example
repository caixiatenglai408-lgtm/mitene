# 管理画面
PORT=5050

# 「ブラウザで開く」で使うブラウザ（macOS のアプリ名。未設定時は --chrome 既定）
# MITENE_BROWSER_APP=Google Chrome
FLASK_SECRET_KEY=change-me-to-random-string

# 女の子パスワード暗号化（推奨）
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MITENE_SECRET_KEY=

# CLI単体実行用（管理画面利用時は不要）
HIMEDECO_LOGIN_ID=
HIMEDECO_PASSWORD=
HIMEDECO_BASE_URL=
AUTH_STATE_PATH=playwright/.auth/himedeco.json
